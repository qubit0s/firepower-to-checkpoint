---
# yamllint config for the Firepower -> Check Point toolkit.
extends: default

rules:
  line-length:
    max: 160
  truthy:
    check-keys: false   # allow Ansible 'yes/no' style without flagging keys
  comments:
    min-spaces-from-content: 1
  # Keep consistent with ansible-lint's embedded yamllint expectations:
  comments-indentation: false
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

ignore: |
  .venv/
  collections/
  reports/
